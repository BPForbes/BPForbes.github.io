PARAMS: A:state B:state Cin:state

MAIN-PROCESS SingleBitFullAdder
CREATETOKEN -I Sum Cout

SET 0:0 $A
SET 1:0 $B
SET 2:0 $Cin
SET Sum:0 0p
SET Cout:0 0p

CNOT -I 0:0 -O Sum:0
CNOT -I 1:0 -O Sum:0
CNOT -I 2:0 -O Sum:0

CCNOT -I 0:0 1:0 -O Cout:0
CCNOT -I 0:0 2:0 -O Cout:0
CCNOT -I 1:0 2:0 -O Cout:0

MEASURE -I Sum
MEASURE -I Cout
RETURNVALS Sum Cout
