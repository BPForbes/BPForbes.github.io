PARAMS: A:state B:state Cin:state

MAIN-PROCESS SingleBitFullAdder
SET $A 0p
SET $B 1p
SET $Cin 1p

CREATETOKEN -I Sum Cout

SET $A:0 0p
SET $B:0 1p
SET $Cin:0 1p
SET Sum:0 0p
SET Cout:0 0p

CNOT -I $A:0 -O Sum:0
CNOT -I $B:0 -O Sum:0
CNOT -I $Cin:0 -O Sum:0

CCNOT -I $A:0 $B:0 -O Cout:0
CCNOT -I $A:0 $Cin:0 -O Cout:0
CCNOT -I $B:0 $Cin:0 -O Cout:0

MEASURE -I Cout:0
MEASURE -I Sum:0

RETURNVALS Cout:0 Sum:0
