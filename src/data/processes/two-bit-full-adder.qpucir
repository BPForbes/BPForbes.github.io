PARAMS: A0:state A1:state B0:state B1:state Cin:state

MAIN-PROCESS TwoBitFullAdder
DECLARECHILD SingleBitFullAdder
CREATETOKEN -I Cmid S0tmp S1tmp

SET Cmid:0 0p

SET A0:0 $A0
SET B0:0 $B0
SET Cin:0 $Cin
RUNCHILD SingleBitFullAdder -I $A0 $B0 $Cin -O Cmid:0 S0tmp
ACCEPTVALS Cmid S0tmp

SET A1:0 $A1
SET B1:0 $B1
RUNCHILD SingleBitFullAdder -I $A1 $B1 Cmid -O Cout S1tmp
ACCEPTVALS Cout S1tmp

RETURNVALS Cout S1tmp S0tmp
